PORT=4000
NODE_ENV=development
TIMEZONE=Asia/Dubai

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Anthropic (Claude Vision - fines verification)
ANTHROPIC_API_KEY=

# SignNow (document signing) - password-grant OAuth
SIGNNOW_BASE_URL=https://api.signnow.com
SIGNNOW_EMAIL=
SIGNNOW_PASSWORD=
SIGNNOW_CLIENT_ID=
SIGNNOW_CLIENT_SECRET=

# TrustIn (escrow partner) - MOCK until real credentials arrive
TRUSTIN_API_KEY=MOCK_REPLACE_LATER
TRUSTIN_BASE_URL=MOCK_REPLACE_LATER
TRUSTIN_MOCK_MODE=true

# WhatsApp Business API - MOCK until approval
WHATSAPP_API_KEY=MOCK_REPLACE_LATER
WHATSAPP_PHONE_NUMBER_ID=MOCK_REPLACE_LATER
WHATSAPP_MOCK_MODE=true

# Auth
JWT_SECRET=

# Company details (for generated documents)
COMPANY_NAME=
COMPANY_REGISTRATION=
COMPANY_SIGNATORY=
COMPANY_EMAIL=
COMPANY_PHONE=
COMPANY_WEBSITE=
COMPANY_IBAN=
COMPANY_ACCOUNT_NAME=
COMPANY_BANK=
ESCROW_PARTNER_NAME=
