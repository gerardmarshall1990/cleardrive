PORT=4000
NODE_ENV=development
TIMEZONE=Asia/Dubai

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# Storage bucket for generated PDFs (DOC-001/002/003/009) — must exist first,
# see supabase/migrations/0004_documents_bucket.sql. Defaults to 'deal-documents'.
SUPABASE_DOCUMENTS_BUCKET=deal-documents

# Anthropic (Claude Vision - fines verification)
ANTHROPIC_API_KEY=

# SignNow (document signing) - password-grant OAuth
SIGNNOW_BASE_URL=https://api.signnow.com
SIGNNOW_EMAIL=
SIGNNOW_PASSWORD=
SIGNNOW_CLIENT_ID=
SIGNNOW_CLIENT_SECRET=
# HMAC secret for verifying incoming /webhooks/signnow requests - leave unset
# until SignNow issues a real webhook signing secret.
SIGNNOW_WEBHOOK_SECRET=

# TrustIn (escrow partner) - MOCK until real credentials arrive
TRUSTIN_API_KEY=MOCK_REPLACE_LATER
TRUSTIN_BASE_URL=MOCK_REPLACE_LATER
TRUSTIN_MOCK_MODE=true
# HMAC secret for verifying incoming /webhooks/trustin requests - leave unset
# in mock mode; set once TrustIn issues a real webhook signing secret.
TRUSTIN_WEBHOOK_SECRET=

# WhatsApp Business API - MOCK until approval
WHATSAPP_API_KEY=MOCK_REPLACE_LATER
WHATSAPP_PHONE_NUMBER_ID=MOCK_REPLACE_LATER
WHATSAPP_MOCK_MODE=true

# App base URL - used to build join/kyc/signing deep links
APP_BASE_URL=http://localhost:5173

# Email (Resend) - MOCK until a real API key is provided
RESEND_API_KEY=MOCK_REPLACE_LATER
EMAIL_FROM="ClearDrive <no-reply@cleardriveuae.com>"
EMAIL_MOCK_MODE=true

# Auth
JWT_SECRET=

# Company details (for generated documents)
COMPANY_NAME=
COMPANY_REGISTRATION=
COMPANY_SIGNATORY=
COMPANY_EMAIL=
COMPANY_PHONE=
COMPANY_WEBSITE=
COMPANY_IBAN=
COMPANY_ACCOUNT_NAME=
COMPANY_BANK=
ESCROW_PARTNER_NAME=
