{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "owner": "cleardrive",
    "version": "1.0.0",
    "scheme": "cleardrive",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cleardriveuae.app"
    },
    "android": {
      "package": "com.cleardriveuae.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ClearDrive to access your photos to upload deal documents (Emirates ID, Mulkiya, fines screenshot, settlement letter)."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "a97fee7a-9c13-4d2a-9b61-52cc555e3967"
      }
    }
  }
}
